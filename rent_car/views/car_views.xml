<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Car Form View -->
    <record id="view_rent_car_form" model="ir.ui.view">
        <field name="name">rent.car.form</field>
        <field name="model">rent.car</field>
        <field name="arch" type="xml">
            <form string="Car">
                <header>
                    <button name="action_set_available" string="Set Available"
                            type="object" invisible="state == 'available'"
                            class="btn-success"/>
                    <button name="action_set_maintenance" string="Set Maintenance"
                            type="object" invisible="state == 'maintenance'"
                            class="btn-warning"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="available,rented,maintenance"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_orders" type="object"
                                class="oe_stat_button" icon="fa-list">
                            <field name="order_count" widget="statinfo"
                                   string="Orders"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Car Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Car Information">
                            <field name="brand"/>
                            <field name="model"/>
                            <field name="year"/>
                            <field name="color"/>
                            <field name="plate_number"/>
                        </group>
                        <group string="Rental Details">
                            <field name="daily_rate" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Enter car description..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Car List View -->
    <record id="view_rent_car_list" model="ir.ui.view">
        <field name="name">rent.car.list</field>
        <field name="model">rent.car</field>
        <field name="arch" type="xml">
            <list string="Cars" decoration-success="state == 'available'"
                  decoration-danger="state == 'maintenance'"
                  decoration-info="state == 'rented'">
                <field name="name"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="year"/>
                <field name="plate_number"/>
                <field name="daily_rate" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="order_count" string="Orders"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-danger="state == 'maintenance'"
                       decoration-info="state == 'rented'"/>
            </list>
        </field>
    </record>

    <!-- Car Kanban View -->
    <record id="view_rent_car_kanban" model="ir.ui.view">
        <field name="name">rent.car.kanban</field>
        <field name="model">rent.car</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="plate_number"/>
                <field name="daily_rate"/>
                <field name="currency_id"/>
                <field name="state"/>
                <field name="image_128"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="d-flex align-items-center mb-2">
                                <field name="image_128" widget="image"
                                       class="o_image_64_max me-2"
                                       options="{'img_class': 'rounded'}"/>
                                <div>
                                    <strong><field name="name"/></strong>
                                    <div class="text-muted small">
                                        <field name="brand"/> <field name="model"/>
                                    </div>
                                    <div class="text-muted small">
                                        Plate: <field name="plate_number"/>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>
                                    <field name="daily_rate" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/> / day
                                </span>
                                <field name="state" widget="badge"
                                       decoration-success="state == 'available'"
                                       decoration-danger="state == 'maintenance'"
                                       decoration-info="state == 'rented'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Car Search View -->
    <record id="view_rent_car_search" model="ir.ui.view">
        <field name="name">rent.car.search</field>
        <field name="model">rent.car</field>
        <field name="arch" type="xml">
            <search string="Cars">
                <field name="name" string="Car" filter_domain="[
                    '|', '|', '|',
                    ('name', 'ilike', self),
                    ('brand', 'ilike', self),
                    ('model', 'ilike', self),
                    ('plate_number', 'ilike', self)
                ]"/>
                <field name="brand"/>
                <field name="plate_number"/>
                <separator/>
                <filter string="Available" name="available"
                        domain="[('state', '=', 'available')]"/>
                <filter string="Rented" name="rented"
                        domain="[('state', '=', 'rented')]"/>
                <filter string="Under Maintenance" name="maintenance"
                        domain="[('state', '=', 'maintenance')]"/>
                <group expand="0" string="Group By">
                    <filter string="Brand" name="group_by_brand"
                            context="{'group_by': 'brand'}"/>
                    <filter string="Status" name="group_by_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Car Action -->
    <record id="action_rent_car" model="ir.actions.act_window">
        <field name="name">Cars</field>
        <field name="res_model">rent.car</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first rental car!
            </p>
            <p>
                Manage your fleet of rental cars here.
            </p>
        </field>
    </record>
</odoo>
