<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Car Rental Manager Group -->
        <record id="group_rent_car_manager" model="res.groups">
            <field name="name">Car Rental / Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('group_rent_car_user'))]"/>
        </record>

        <!-- Car Rental User Group -->
        <record id="group_rent_car_user" model="res.groups">
            <field name="name">Car Rental / User</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>
    </data>
</odoo>
