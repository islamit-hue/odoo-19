<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Rental Branch Tree View -->
    <record id="view_rental_branch_tree" model="ir.ui.view">
        <field name="name">rental.branch.tree</field>
        <field name="model">rental.branch</field>
        <field name="arch" type="xml">
            <list string="Branches">
                <field name="name"/>
                <field name="company_id"/>
                <field name="phone"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Rental Branch Form View -->
    <record id="view_rental_branch_form" model="ir.ui.view">
        <field name="name">rental.branch.form</field>
        <field name="model">rental.branch</field>
        <field name="arch" type="xml">
            <form string="Rental Branch">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Branch Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Address">
                        <field name="address" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Rental Branch Action -->
    <record id="action_rental_branch" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">rental.branch</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_fleet_rental_root"
              name="Fleet Rental"
              sequence="90"
              web_icon="fleet_rental_contracts,static/src/img/icon.png"/>

    <menuitem id="menu_fleet_rental_contracts"
              name="Contracts"
              parent="menu_fleet_rental_root"
              sequence="10"/>

    <menuitem id="menu_fleet_rental_configuration"
              name="Configuration"
              parent="menu_fleet_rental_root"
              sequence="90"/>

    <menuitem id="menu_rental_branch"
              name="Branches"
              parent="menu_fleet_rental_configuration"
              action="action_rental_branch"
              sequence="10"/>
</odoo>
