<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== Rental Contract Views ==================== -->
    <record id="view_rental_contract_search" model="ir.ui.view">
        <field name="name">rental.contract.search</field>
        <field name="model">rental.contract</field>
        <field name="arch" type="xml">
            <search string="Search Contracts">
                <field name="name" string="Contract #"/>
                <field name="partner_id" string="Customer"/>
                <field name="vehicle_id" string="Vehicle"/>
                <field name="branch_id" string="Branch"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Open" name="open" domain="[('state','=','open')]"/>
                <filter string="Suspended" name="suspended" domain="[('state','=','suspended')]"/>
                <filter string="Closed" name="closed" domain="[('state','=','closed')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state','=','cancelled')]"/>
                <separator/>
                <filter string="Legal" name="legal" domain="[('state','=','legal')]"/>
                <filter string="Insurance" name="insurance" domain="[('state','=','insurance')]"/>
                <group expand="0" string="Group By">
                    <filter string="Branch" name="group_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_rental_contract_list" model="ir.ui.view">
        <field name="name">rental.contract.list</field>
        <field name="model">rental.contract</field>
        <field name="arch" type="xml">
            <list string="Rental Contracts" decoration-success="state == 'open'"
                decoration-warning="state == 'suspended'"
                decoration-danger="state in ('legal','insurance')"
                decoration-muted="state in ('closed','cancelled')">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="vehicle_id"/>
                <field name="branch_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="amount_due" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'open'"
                    decoration-warning="state == 'suspended'"
                    decoration-danger="state in ('legal','insurance')"
                    decoration-secondary="state in ('closed','cancelled')"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_rental_contract_form" model="ir.ui.view">
        <field name="name">rental.contract.form</field>
        <field name="model">rental.contract</field>
        <field name="arch" type="xml">
            <form string="Rental Contract">
                <header>
                    <button name="action_open" string="Confirm / Open" type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"/>
                    <button name="action_suspend" string="Suspend" type="object"
                        invisible="state != 'open'"/>
                    <button name="action_close" string="Close Contract" type="object"
                        class="btn-primary"
                        invisible="state not in ('open','suspended')"/>
                    <button name="action_send_to_legal" string="Send to Legal" type="object"
                        invisible="state not in ('open','suspended')"/>
                    <button name="action_send_to_insurance" string="Send to Insurance" type="object"
                        invisible="state not in ('open','suspended')"/>
                    <button name="action_cancel" string="Cancel" type="object"
                        invisible="state in ('closed','cancelled')"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                        invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,open,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_violations" type="object"
                            class="oe_stat_button" icon="fa-exclamation-triangle"
                            invisible="violation_count == 0">
                            <field name="violation_count" widget="statinfo" string="Violations"/>
                        </button>
                    </div>
                    <group>
                        <group string="Contract Information">
                            <field name="name"/>
                            <field name="branch_id"/>
                            <field name="close_branch_id"/>
                            <field name="inter_branch_delivery_fee" widget="monetary"
                                options="{'currency_field': 'currency_id'}"
                                invisible="not close_branch_id"/>
                        </group>
                        <group string="Customer">
                            <field name="partner_id"/>
                            <field name="partner_type"/>
                            <field name="customer_source"/>
                            <field name="additional_driver_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <group string="Vehicle &amp; Pricing">
                            <field name="vehicle_id"/>
                            <field name="pricing_id"/>
                            <field name="insurance_type"/>
                            <field name="currency_id"/>
                        </group>
                        <group string="Schedule">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="actual_return_date"/>
                            <field name="grace_minutes"/>
                        </group>
                    </group>
                    <group>
                        <group string="Mileage">
                            <field name="km_start"/>
                            <field name="km_end"/>
                            <field name="km_driven"/>
                            <field name="allowed_km"/>
                            <field name="extra_km"/>
                        </group>
                        <group string="Financial Summary">
                            <field name="base_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="insurance_charge" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="delivery_charge" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="deductible_charge" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="open_km_charge" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="extra_km_charge" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="extra_driver_charge" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="deposit_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="advance_payment" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="amount_paid" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="amount_due" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Check-Out Checklist" name="checkout">
                            <field name="checkout_checklist_ids">
                                <list editable="bottom">
                                    <field name="item_id"/>
                                    <field name="checklist_type" column_invisible="1"
                                        default="checkout"/>
                                    <field name="condition"/>
                                    <field name="notes"/>
                                    <field name="image" widget="image"
                                        options="{'size': [60, 60]}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Check-In Checklist" name="checkin">
                            <field name="checkin_checklist_ids">
                                <list editable="bottom">
                                    <field name="item_id"/>
                                    <field name="checklist_type" column_invisible="1"
                                        default="checkin"/>
                                    <field name="condition"/>
                                    <field name="notes"/>
                                    <field name="image" widget="image"
                                        options="{'size': [60, 60]}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Violations" name="violations">
                            <field name="violation_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="violation_type"/>
                                    <field name="violation_date"/>
                                    <field name="amount" widget="monetary"
                                        options="{'currency_field': 'currency_id'}"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes_page">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_rental_contract" model="ir.actions.act_window">
        <field name="name">Rental Contracts</field>
        <field name="res_model">rental.contract</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_open': 1}</field>
    </record>

    <record id="action_rental_contract_all" model="ir.actions.act_window">
        <field name="name">All Contracts</field>
        <field name="res_model">rental.contract</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
