<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Branch Form View -->
    <record id="view_fleet_rental_branch_form" model="ir.ui.view">
        <field name="name">fleet.rental.branch.form</field>
        <field name="model">fleet.rental.branch</field>
        <field name="arch" type="xml">
            <form string="Rental Branch">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Branch Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Location">
                            <field name="street"/>
                            <field name="city"/>
                            <field name="phone"/>
                        </group>
                        <group string="Management">
                            <field name="manager_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Branch List View -->
    <record id="view_fleet_rental_branch_list" model="ir.ui.view">
        <field name="name">fleet.rental.branch.list</field>
        <field name="model">fleet.rental.branch</field>
        <field name="arch" type="xml">
            <list string="Rental Branches">
                <field name="name"/>
                <field name="city"/>
                <field name="phone"/>
                <field name="manager_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Branch Action -->
    <record id="action_fleet_rental_branch" model="ir.actions.act_window">
        <field name="name">Rental Branches</field>
        <field name="res_model">fleet.rental.branch</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first rental branch
            </p>
        </field>
    </record>

    <!-- Configuration Menu -->
    <menuitem id="menu_fleet_rental_config"
        name="Configuration"
        parent="menu_fleet_rental_root"
        sequence="90"/>

    <menuitem id="menu_fleet_rental_branch"
        name="Branches"
        parent="menu_fleet_rental_config"
        action="action_fleet_rental_branch"
        sequence="10"/>

</odoo>
