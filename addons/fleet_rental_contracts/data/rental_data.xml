<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for Rental Contracts -->
        <record id="seq_fleet_rental_contract" model="ir.sequence">
            <field name="name">Fleet Rental Contract</field>
            <field name="code">fleet.rental.contract</field>
            <field name="prefix">RC/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Default Checkout Checklist Template Items -->
        <record id="rental_branch_main" model="fleet.rental.branch">
            <field name="name">Main Branch</field>
        </record>

    </data>
</odoo>
