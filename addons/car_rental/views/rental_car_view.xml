<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view -->
    <record id="view_rental_car_list" model="ir.ui.view">
        <field name="name">rental.car.list</field>
        <field name="model">rental.car</field>
        <field name="arch" type="xml">
            <list string="السيارات">
                <field name="name"/>
                <field name="license_plate"/>
                <field name="brand"/>
                <field name="model_year"/>
                <field name="daily_rate"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-warning="state == 'maintenance'"
                       decoration-danger="state == 'rented'"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_rental_car_form" model="ir.ui.view">
        <field name="name">rental.car.form</field>
        <field name="model">rental.car</field>
        <field name="arch" type="xml">
            <form string="سيارة">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="اسم السيارة"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="license_plate"/>
                            <field name="brand"/>
                            <field name="model_year"/>
                        </group>
                        <group>
                            <field name="daily_rate"/>
                            <field name="state" widget="statusbar"
                                   statusbar_visible="available,rented,maintenance"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban view -->
    <record id="view_rental_car_kanban" model="ir.ui.view">
        <field name="name">rental.car.kanban</field>
        <field name="model">rental.car</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="license_plate"/>
                <field name="brand"/>
                <field name="daily_rate"/>
                <field name="state"/>
                <field name="image"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('rental.car', 'image', record.id.raw_value)"
                                     alt="صورة السيارة"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><field name="license_plate"/></div>
                                <div><field name="brand"/></div>
                                <div>السعر اليومي: <field name="daily_rate"/></div>
                                <div><field name="state" widget="badge"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="action_rental_car" model="ir.actions.act_window">
        <field name="name">السيارات</field>
        <field name="res_model">rental.car</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                أضف سيارتك الأولى للتأجير!
            </p>
        </field>
    </record>
</odoo>
